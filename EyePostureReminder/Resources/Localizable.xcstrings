    "legal.terms.notMedical.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not Medical Advice"
          }
        }
      }
    },
    "legal.terms.notMedical.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is designed to support healthy screen habits. It is not medical advice. Consult a healthcare professional for eye or posture concerns."
          }
        }
      }
    },
    "legal.terms.professional.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Professional Guidance"
          }
        }
      }
    },
    "legal.terms.professional.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you experience eye strain, neck pain, or related symptoms, seek advice from a qualified optometrist or physiotherapist."
          }
        }
      }
    },
    "legal.terms.liability.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limitation of Liability"
          }
        }
      }
    },
    "legal.terms.liability.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The developer is not liable for any health outcomes resulting from use or non-use of this app."
          }
        }
      }
    },
    "legal.terms.warranty.heading": {
      "extractionState": "manual",
      "localizations": {
