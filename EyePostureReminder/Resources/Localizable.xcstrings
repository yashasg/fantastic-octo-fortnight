    "legal.terms.contact.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact"
          }
        }
      }
    },
    "legal.terms.contact.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For questions or concerns, contact the developer through the App Store listing."
          }
        }
      }
    },
    "legal.privacy.collect.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data We Collect"
          }
        }
      }
    },
    "legal.privacy.collect.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reminder preferences, settings, and local True Interrupt coordination metadata are stored on your device using UserDefaults. No data is sent to a developer server. The app also reads motion activity state and Focus mode status in memory only (never stored) to pause reminders while driving or during Focus sessions."
          }
        }
      }
    },
    "legal.privacy.noCollect.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What We Don't Collect"
          }
        }
      }
    },
    "legal.privacy.noCollect.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We do not collect personal information, track you, or send app data to a developer server. Apple may process limited diagnostics, crash data, TestFlight feedback, and App Store analytics through Apple’s systems if your device or TestFlight settings allow it. Motion activity data is accessed transiently in memory to pause reminders while driving and is never stored or transmitted by kshana. Diagnostic events are logged locally via Apple’s os.Logger: setting values (old and new) are marked private and redacted in exported logs; timing and duration measurements are non-identifying operational metrics."
          }
        }
      }
    },
    "legal.privacy.rights.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Rights"
          }
        }
      }
    },
    "legal.privacy.rights.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Since kshana does not maintain user accounts or a user-level database, most data subject rights are satisfied by default. To delete all App data, simply delete the App from your device. Local settings and coordination metadata may be included in your device’s iCloud backup if iCloud backup is enabled.\n\nGDPR (EU/EEA users): We do not maintain a user-level profile or account database for access, deletion, or portability requests. Apple-native diagnostics and App Store data are handled through Apple’s systems and your Apple privacy settings.\n\nCCPA (California users): We do not sell or share personal information for cross-context behavioral advertising. We do not track you across apps or websites."
          }
        }
      }
    },
    "legal.privacy.contact.heading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact"
          }
        }
      }
    },
    "legal.privacy.contact.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For privacy questions, contact the developer through the App Store listing."
          }
        }
      }
    },
