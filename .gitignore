# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Xcode / Swift Package Manager
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.xcscmblueprint

# Swift build artifacts
.build/
.swiftpm/

# macOS
.DS_Store
.AppleDouble
.LSOverride
TestResults*.xcresult/
UITestResults.xcresult/

# XcodeGen-generated UITest project (generated from UITests/project.yml)
UITests/*.xcodeproj/
UITests/*.xcworkspace/

# One-time scripts and tool output logs
fix_multiline.py
manual_violations.txt
other_violations.txt
swiftlint_violations.txt
excalidraw.log

# Build/audit artifacts (one-off binaries and logs — never commit)
audit_check
build_check.log
build_output.log
audit_workflows.sh
detailed_audit.py
detailed_manual_audit.sh
edge_case_audit.sh
final_audit.sh
script_validation.sh

# Dev artifacts (screenshots, issue dumps, preview files)
*.png
*.jpeg
*-issues.json
uitest_run.log
yinyang-preview.html
